# Cloudflare's documented always-pass Turnstile test credentials.
# These values are for local development only and must never be used in production.
TURNSTILE_SITE_KEY="1x00000000000000000000AA"
TURNSTILE_SECRET_KEY="1x0000000000000000000000000000000AA"

# Use a restricted SendGrid API key in your untracked .dev.vars file.
SENDGRID_API_KEY="REPLACE_WITH_LOCAL_SENDGRID_API_KEY"
CONTACT_TO_EMAIL="hello@diehard.cards"
CONTACT_FROM_EMAIL="no-reply@diehard.cards"
